# ============================================================
# Variables d'environnement — Trente Deux
# Copier ce fichier en .env.local et renseigner les valeurs
# NE JAMAIS committer le fichier .env.local
# ============================================================

# --- Resend (envoi email formulaire de contact) ---
# Clé API Resend (obtenue sur resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Adresse expéditrice (doit être un domaine vérifié dans Resend)
RESEND_FROM_EMAIL=Trente Deux <no-reply@trentedeux.fr>

# Adresse destinataire des demandes de contact
RESEND_TO_EMAIL=contact@trentedeux.fr

# --- Calendly ---
# URL de votre page Calendly (format embed inline)
# Exemple : https://calendly.com/votre-compte/consultation-strategique
REACT_APP_CALENDLY_URL=

# --- API (pour le formulaire de contact côté frontend) ---
# En développement local : laisser vide (la serverless function tourne sur le même serveur Vercel)
# En production : laisser vide aussi (Vercel route /api/* automatiquement)
REACT_APP_API_URL=
